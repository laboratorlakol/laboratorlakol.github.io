generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  MEMBER
  HELPER
  MODERATOR
  ADMINISTRATOR
  SUPERVISOR
  COMMUNITY_MANAGER
  CO_FOUNDER
  FOUNDER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum NewsCategory {
  UPDATES
  EVENTS
  ANNOUNCEMENTS
  DEVELOPMENT_LOGS
}

enum TicketCategory {
  REPORT_PLAYER
  REPORT_STAFF
  SANCTION_APPEAL
  CONTACT_FOUNDER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique
  email         String        @unique
  passwordHash  String
  role          Role          @default(MEMBER)
  status        AccountStatus @default(ACTIVE)
  emailVerified Boolean       @default(false)
  citizenId     String?       @unique
  characterName String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]
  warnings                Warning[]
  timeouts                Timeout[]
  bans                    Ban[]
  forumTopics             ForumTopic[]
  forumPosts              ForumPost[]
  tickets                 Ticket[]
  ticketMessages          TicketMessage[]
  ticketParticipations    TicketParticipant[]

  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Warning {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  issuedBy  String
  createdAt DateTime @default(now())
  @@index([userId])
}

model Timeout {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason   String
  issuedBy String
  startsAt DateTime  @default(now())
  endsAt   DateTime
  liftedAt DateTime?
  @@index([userId])
}

model Ban {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  issuedBy  String
  permanent Boolean   @default(false)
  expiresAt DateTime?
  liftedAt  DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
}

model FiveMLinkCode {
  id            String    @id @default(cuid())
  codeHash      String    @unique
  citizenId     String
  characterName String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  @@index([citizenId])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  avatarUrl String?
  position  Int      @default(0)
  visible   Boolean  @default(true)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([position])
}

model NewsPost {
  id        String       @id @default(cuid())
  title     String
  excerpt   String
  content   String
  category  NewsCategory @default(UPDATES)
  published Boolean      @default(false)
  authorId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@index([published])
  @@index([category])
}

model ForumCategory {
  id               String  @id @default(cuid())
  name             String
  description      String?
  slug             String  @unique
  position         Int     @default(0)
  pinned           Boolean @default(false)
  staffOnlyReplies Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  topics           ForumTopic[]
  @@index([position])
}

model ForumTopic {
  id         String        @id @default(cuid())
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  posts      ForumPost[]
  @@index([categoryId])
  @@index([pinned])
}

model ForumPost {
  id          String     @id @default(cuid())
  topicId     String
  topic       ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content     String
  isFirstPost Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([topicId])
}

model RegulationChapter {
  id        String              @id @default(cuid())
  title     String
  position  Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  articles  RegulationArticle[]
  @@index([position])
}

model RegulationArticle {
  id        String            @id @default(cuid())
  chapterId String
  chapter   RegulationChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title     String
  content   String
  position  Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  @@index([chapterId])
}

model Ticket {
  id           String         @id @default(cuid())
  subject      String
  category     TicketCategory @default(REPORT_PLAYER)
  status       TicketStatus   @default(OPEN)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     TicketMessage[]
  participants TicketParticipant[]
  @@index([userId])
  @@index([status])
  @@index([category])
}

model TicketMessage {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content      String
  isStaffReply Boolean  @default(false)
  createdAt    DateTime @default(now())
  @@index([ticketId])
}

model TicketParticipant {
  id       String   @id @default(cuid())
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt  DateTime @default(now())
  @@unique([ticketId, userId])
  @@index([ticketId])
}
