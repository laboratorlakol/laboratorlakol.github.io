// FADED Romania Roleplay — database schema
// Provider: PostgreSQL (Neon free tier recommended)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon's pooled connection string goes in DATABASE_URL (used at runtime).
  // directUrl is the *unpooled* connection, required by `prisma migrate`.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Role hierarchy, low -> high (order matters — see lib/auth/rbac.ts).
// MEMBER is the default rank everyone gets on registration; everything
// above HELPER is a staff rank.
enum Role {
  MEMBER
  HELPER
  MODERATOR
  ADMINISTRATOR
  SUPERVISOR
  COMMUNITY_MANAGER
  CO_FOUNDER
  FOUNDER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  role          Role     @default(MEMBER)
  status        AccountStatus @default(ACTIVE)
  emailVerified Boolean  @default(false)

  // Filled in once the player links their website account to their
  // in-game character via the /codsite flow (phase 3 — FiveM integration).
  citizenId     String?  @unique
  characterName String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens          RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]
  warnings                Warning[]
  timeouts                Timeout[]
  bans                    Ban[]
  forumTopics             ForumTopic[]
  forumPosts              ForumPost[]

  @@index([email])
  @@index([username])
}

// One row per /codsite use in-game. Short-lived, single-use — the website
// consumes it to permanently set User.citizenId.
model FiveMLinkCode {
  id            String    @id @default(cuid())
  codeHash      String    @unique
  citizenId     String
  characterName String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([citizenId])
}

// One row per issued refresh token (hashed, never stored in plaintext).
// Lets us revoke a single session ("log out this device") instead of all.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Append-only trail for every security-relevant action — required by the
// brief ("Staff Logs"): logins, role changes, bans, password resets, etc.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Warning {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  issuedBy  String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Timeout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  issuedBy  String
  startsAt  DateTime @default(now())
  endsAt    DateTime
  liftedAt  DateTime?

  @@index([userId])
}

model Ban {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason      String
  issuedBy    String
  permanent   Boolean  @default(false)
  expiresAt   DateTime?
  liftedAt    DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// --- CMS -------------------------------------------------------------------
// Simple key/value store for site-wide settings an admin can change without
// touching code: Tebex URL, Discord invite link, etc.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Drives the "Echipă" section on the homepage. `role` is a free-text label
// (not the Role enum) so staff can be listed under a friendly title that
// doesn't have to match their website permission rank 1:1.
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  avatarUrl String?
  position  Int      @default(0) // display order, lower = first
  visible   Boolean  @default(true)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

enum NewsCategory {
  UPDATES
  EVENTS
  ANNOUNCEMENTS
  DEVELOPMENT_LOGS
}

// Drives the "Noutăți" section on the homepage.
model NewsPost {
  id          String       @id @default(cuid())
  title       String
  excerpt     String
  content     String
  category    NewsCategory @default(UPDATES)
  published   Boolean      @default(false)
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published])
  @@index([category])
}

// --- Forum -------------------------------------------------------------
// Categories are created and managed entirely from /admin — nothing is
// pre-seeded, per the brief.
model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  position    Int      @default(0)
  pinned      Boolean  @default(false)

  // If true, only the topic's own author + Supervisor-and-above can post
  // replies (anyone can still view, and any member can still start their
  // own topic — e.g. their own staff application). This is what gives
  // Supervisor's "comment on Staff Application threads" permission an
  // actual purpose.
  staffOnlyReplies Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topics    ForumTopic[]

  @@index([position])
}

model ForumTopic {
  id         String        @id @default(cuid())
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  posts      ForumPost[]

  @@index([categoryId])
  @@index([pinned])
}

model ForumPost {
  id          String     @id @default(cuid())
  topicId     String
  topic       ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content     String
  isFirstPost Boolean    @default(false) // the topic's own body, rendered as the OP
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([topicId])
}

// --- Regulament ----------------------------------------------------------
// Hierarchical chapters -> articles, fully managed from /admin. Nothing
// pre-seeded, per the brief.
model RegulationChapter {
  id        String   @id @default(cuid())
  title     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  articles  RegulationArticle[]

  @@index([position])
}

model RegulationArticle {
  id        String            @id @default(cuid())
  chapterId String
  chapter   RegulationChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title     String
  content   String
  position  Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([chapterId])
}
